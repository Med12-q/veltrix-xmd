# ============================================
#   VELTRIX XMD V2 — Configuration
# ============================================

# Préfixe des commandes WhatsApp (défaut: .)
PREFIXE=.

# Dossier de session Baileys
DOSSIER_AUTH=auth_baileys

# Numéro WhatsApp fallback (si Telegram non dispo)
NUMBER=224610835573

# Connexion : false = pairing Telegram | true = QR code
USE_QR=false

# --- TELEGRAM ---
# Token obtenu via @BotFather sur Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# IDs Telegram autorisés (vide = tout le monde)
TELEGRAM_ALLOWED_IDS=

# --- OWNERS WhatsApp (sans +, séparés par virgule) ---
OWNER_NUMBERS=224610835573,224669288332

# Délai de reconnexion en ms
RECONNECT_DELAY=5000
